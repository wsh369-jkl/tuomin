# 应用配置
APP_NAME=合同脱敏系统
APP_VERSION=2.0.0
DEBUG=False

# API 配置
APP_HOST=127.0.0.1
APP_PORT=8000
API_V1_PREFIX=/api/v1

# 默认识别模式：本机高质量线。需要低内存时可改为 high_quality_lowmem。
DESENSITIZE_MODE=high_quality_lowmem

# 旧 Ollama 路线保留为 legacy/baseline；高质量低内存模式不走 Ollama 全文抽取
LLM_BACKEND=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_MODEL_OPTIONS=qwen3:14b,qwen3.5:9b,qwen3:8b,qwen3.5:4b,qwen3.6:27b
OLLAMA_TIMEOUT=600
OLLAMA_NUM_CTX=4096

# 高质量低内存模型目录和主识别模型
LOWMEM_MODEL_ROOT=~/.contract-desensitize/models
PRIMARY_IE_MODEL=uer/roberta-base-finetuned-cluener2020-chinese
PRIMARY_NER_MODEL=p988744/eland-ner-zh
SECONDARY_NER_MODEL=shibing624/bert4ner-base-chinese

# 稳定默认后端
# PRIMARY_IE_BACKEND=modelscope 需要隔离验证；旧 UIE 模型远程 requirements 可能拉 transformers 4.x，与 mlx-lm 冲突。
PRIMARY_IE_BACKEND=transformers_token_classification
PRIMARY_NER_BACKEND=transformers
SECONDARY_NER_BACKEND=transformers
ALLOW_UNSAFE_MODELSCOPE_UIE_RUNTIME=False

# 三层片段审查：14B/9B/8B/4B 主审查，27B 只做疑难仲裁；不要让大模型做扫描 PDF OCR
REVIEW_MODEL=Qwen/Qwen3-1.7B-MLX-4bit
REVIEW_MODEL_FALLBACK=unsloth/Qwen3.5-0.8B-GGUF/Qwen3.5-0.8B-Q4_K_M.gguf
REVIEW_BACKEND=mlx
REVIEW_MODEL_FALLBACK_BACKEND=llama_cpp
REVIEW_LAZY_LOAD=True
REVIEW_UNLOAD_AFTER_TASK=True
REVIEW_NUM_CTX=1536
REVIEW_MAX_TOKENS=384
REVIEW_TEMPERATURE=0.0
REVIEW_MAX_SNIPPETS=10
REVIEW_MAX_CHARS_PER_SNIPPET=1200
MID_REVIEW_MODEL=qwen3:14b
FAST_REVIEW_MODEL=qwen3:8b
HEAVY_ARBITRATION_MODEL=qwen3.6:27b
ENABLE_HEAVY_ARBITRATION=True
HEAVY_ARBITRATION_MAX_SNIPPETS=3
MID_REVIEW_MAX_SNIPPETS=12
REVIEW_THINKING_MODE=off
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1

# 质量策略
ENABLE_PRIMARY_UIE=True
ENABLE_PRIMARY_NER=True
ENABLE_SECONDARY_NER=False
ENABLE_QWEN_REVIEW=True
LOWMEM_UNLOAD_PRIMARY_AFTER_STAGE=True
ANALYSIS_WORKER_PROCESS=True
ANALYSIS_STAGE_ISOLATION=True
ANALYSIS_WORKER_TIMEOUT=900
PROCESS_WORKER_TIMEOUT=1800
ANALYSIS_WORKER_PYTHON=
ANALYSIS_WORKER_PYTHON_CHECK_TIMEOUT=45
QUALITY_POLICY=recall_first
LOW_CONFIDENCE_ACTION=keep_and_review
ALIAS_PROPAGATION=True
STRUCTURED_BACKFILL=True
RULE_RESULTS_ARE_AUTHORITATIVE=True
MODEL_RESULTS_CAN_ONLY_ADD=True
MODEL_RESULTS_CANNOT_DELETE_RULE_RESULTS=True

# OCR / PDF
PDF_OCR_ENABLED=True
PDF_OCR_TIMEOUT=90
PDF_OCR_TEXT_THRESHOLD=80
PDF_OCR_MIN_READABLE_RATIO=0.45
PDF_OCR_RENDER_SCALE=2.0
PDF_OCR_IMAGE_MAX_EDGE=2200
PDF_OCR_JPEG_QUALITY=88
PDF_NORMALIZE_TO_DOCX=True
PDF_NORMALIZE_MAX_IMAGE_EDGE=1800
PDF_NORMALIZE_PAGE_CONCURRENCY=1
PDF_NORMALIZE_WORKER_PROCESS=True
PDF_NORMALIZE_WORKER_TIMEOUT=900
PDF_OCR_ENGINE=rapidocr
PDF_OCR_MODEL=ppocrv5_mobile
PDF_OCR_ACCURACY_PROFILE=wps_challenger
PDF_OCR_ENABLE_ANGLE_CLS=False
PDF_OCR_REC_BATCH_NUM=1
PDF_OCR_MAX_CANDIDATES=3
PDF_OCR_LOW_QUALITY_MAX_CANDIDATES=5
PDF_OCR_LOCAL_RETRY_MAX_REGIONS=12
PDF_OCR_LINE_RETRY_UPSCALE=1.6
