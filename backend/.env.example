# 应用配置
APP_NAME=合同脱敏系统
APP_VERSION=2.0.0
DEBUG=True

# API配置
API_V1_PREFIX=/api/v1

# LLM 后端配置
LLM_BACKEND=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_MODEL_OPTIONS=qwen3.5:4b
OLLAMA_TIMEOUT=600
OLLAMA_NUM_CTX=4096

# vLLM 配置（仅在 LLM_BACKEND=vllm 时使用）
LLM_MODEL_NAME=Qwen/Qwen2.5-3B-Instruct
# LLM_MODEL_PATH=./models/qwen2.5-3b
LLM_MAX_LENGTH=4096
LLM_GPU_MEMORY_UTILIZATION=0.85
LLM_TENSOR_PARALLEL_SIZE=1
LLM_DTYPE=float16

USE_VLLM_SERVER=False
VLLM_API_BASE=

# 文件配置
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs
MAX_UPLOAD_SIZE=52428800
DATABASE_URL=

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
